  "verbGlossary": {
    "INSPECTS": "{source} physically examines work and generates or evaluates a quality/{target}",
    "EVALUATES": "{source} process assesses individual items or line-level findings within a quality/{target}",
    "VALIDATES": "{source} action confirms that a quality/{target} meets code or standard requirements",
    "REQUIRES": "{source} or regulatory process mandates that a specific quality/{target} must exist or be completed",
    "CERTIFIES": "{source}{target} formally attests to the acceptability of test results or records",
    "MANDATES": "{source} compels a class of inspections or observations to be performed",
    "CITES": "{source} review references a quality/{target} as evidence of non-compliance",
    "GOVERNS": "{source} framework establishes the rules and standards that quality/{target}s must follow",
    "ENFORCES": "{source} takes action based on violations documented in quality/{target}s",
    "TRIGGERS": "{source} event initiates a required quality/{target} or record",
    "PRESCRIBES": "{source} plan defines the corrective actions or action plans that must be followed",
    "DEFERS": "Temporary certificate acknowledges outstanding items to be resolved after conditional approval",
    "CLEARS": "{source}formally closes out non-conformances or {target} findings",
    "SCHEDULES": "{source} lifecycle process sets the timing for required quality/{target}s",
    "CORRELATES": "{source} measure and quality/safety measure track the same underlying performance dimension",
    "CAUSED_BY": "{source} hold or delay is directly attributable to an unresolved quality/{target}",
    "TRACKS": "{source}document completeness monitors the status of quality/{target}s and closure rates",
    "BLOCKS_UNTIL": "{source} status remains held until the referenced quality/{target} or action plan is resolved",
    "CONDITIONS": "Zoning or land-use approval imposes environmental or quality monitoring conditions",
    "ISSUES": "{source} inspector formally produces {target} notice or finding as an output of inspection"
  }
}