  "verbGlossary": {
    "ACCESSED FROM": "{source} provides entry or egress to {target}; doors, elevators, and openings that people pass through",
    "APPLIED AT": "{source} is adhered, coated, or layered onto a surface or {target}; membranes, waterproofing, insulation, paint, drywall",
    "ATTACHED TO": "{source} is mechanically fastened to a surface; cladding panels and masonry veneer secured to the wall plane",
    "BALANCED WITHIN": "{source} airflow or hydronic flow is tested and adjusted to meet design targets within a commissioning {target}",
    "BEARS ON": "{source} transfers structural load into the ground at a below-grade {target}",
    "DRAINS": "{source} collects and removes water from {target}",
    "ENCLOSES": "{source} forms a boundary that contains or separates {target} from its surroundings; walls, curtain walls, fencing",
    "FRAMES": "{source} provides the structural skeleton that defines the shape of a room or partition at {target}",
    "INSTALLED AT": "{source} is permanently placed at {target}; slabs at floor level, site improvements at exterior zones",
    "INSTALLED IN": "{source} is fitted within an enclosed {target}; fixtures, ceilings, flooring, and devices inside rooms or wet areas",
    "LOCATED AT": "{source} occupies a fixed position at a specific point; columns at {target} lines, equipment on pads",
    "LOCATED IN": "{source} is situated within a vertical enclosure; {target}s in shafts, equipment in dedicated rooms",
    "MONITORS": "{source} observes and reports conditions across {target} zone; building automation sensing temperature and status",
    "OPERATES AT": "{source} runs at {target} to maintain conditions; dewatering pumps working at below-grade levels",
    "PENETRATES": "{source} passes through a boundary or surface at an opening; pipes, ducts, and conduit through fire-rated or structural assemblies",
    "PERFORMED AT": "{target} work activity is executed at a project-level location; excavation, backfill, and grading operations",
    "PROTECTS": "{source} safeguards {target} from environmental damage; erosion control at exterior zones",
    "ROUTED THROUGH": "{source} follows a path through {target}; piping in shafts, ductwork in plenums, utilities in rights-of-way",
    "ROUTED TO": "{source} terminates at a destination {target}; gas piping delivered to equipment locations",
    "SERVES": "{source} provides utility, conditioning, or coverage to {target}; HVAC serving zones, sprinklers protecting compartments, lighting illuminating spaces",
    "SPANS": "{source} extends continuously across or between multiple {target}s; columns spanning floors, beams spanning bays, elevator cars traversing levels"
  }
