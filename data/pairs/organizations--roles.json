  "verbGlossary": {
    "EMPLOYS": "{source} hires and maintains {target} as a permanent or long-term staff position within its corporate structure, providing salary, benefits, and career development.",
    "STAFFS": "{source} assigns {target} to a specific project from its internal labor pool, deploying the person on-site or to the project team for the duration of the engagement.",
    "RETAINS": "{source} engages a representative under a consulting or advisory arrangement rather than direct employment, typically through a professional services agreement.",
    "PROVIDES": "{source} furnishes personnel in {target} to the project as part of its contractual obligation, with the workers remaining employees of the providing firm.",
    "ASSIGNS": "{source} designates a person to fill {target} on a specific project, typically on a part-time or shared basis across multiple jobsites.",
    "DESIGNATES": "{source} names a point-of-contact in {target} for coordination with the GC, as required by the subcontract terms.",
    "DELEGATES TO": "{source} transfers day-to-day project authority to {target}, empowering that person to make decisions on the owner's behalf within defined limits.",
    "LICENSES": "{source}certifies or credentials {target}, granting the legal authority to perform inspections, sign off on safety compliance, or practice a regulated discipline.",
    "MEASURES": "{source} tracks a staffing or workload metric for {target} to ensure adequate project coverage and balanced assignments."
  }
