  "verbGlossary": {
    "APPLIED": "Coating, membrane, or insulation element is adhered or sprayed onto a substrate during a building enclosure {target}; waterproofing, air barriers, and exterior insulation",
    "APPLIED DURING": "Protective layer or treatment is applied to {target} while a foundation or below-grade phase is active; waterproofing membranes on foundation walls",
    "BUILT": "{source} is constructed in place during a late-{target} or closeout phase; paving, sidewalks, landscaping, and fencing",
    "BUILT DURING": "{source} is constructed or placed in its permanent position during the associated earthwork, foundation, or site utility {target}",
    "ENCLOSED": "{source} is installed to seal the building envelope during an enclosure {target}; curtain wall, windows, doors, masonry veneer, roofing, and flashing that achieve weather-tight conditions",
    "ENERGIZED": "{source} is permanently connected to power and made live during the systems startup {target}",
    "ERECTED": "{source} is lifted, aligned, and bolted or welded into position during the steel erection or stairs {target}",
    "INSTALLED": "{source} is permanently fixed in place during a rough-in, trim, or finish {target}; MEP distribution, devices, fixtures, framing, drywall, ceilings, flooring, and casework",
    "POURED": "{source} is placed and finished for a structural slab element during the elevated concrete {target}",
    "SET": "{source}is rigged and placed on its permanent mounting during a rough-in or startup {target}; AHUs, boilers, chillers, water heaters, fire pumps, and elevator machinery",
    "STARTED": "{source} is energized, run, and verified for basic operational readiness during the systems startup {target}; AHUs, heating units, and cooling equipment initial startup sequences",
    "TESTED": "{source} or system is functionally verified against design criteria during a commissioning, pre-functional, or integrated systems testing {target}; TAB, fire alarm, sprinkler, elevator, emergency power, controls, and BAS"
  }
