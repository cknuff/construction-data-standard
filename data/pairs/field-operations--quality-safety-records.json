  "verbGlossary": {
    "ASSIGNED TO": "{source} crew or person designated to execute a corrective or remediation task",
    "CAUSED BY": "{source}record traces its root cause back to a quality, safety, or coordination failure",
    "COLLECTS": "{source} gathers witness statements or supporting evidence for an {target} record",
    "CONTRIBUTES TO": "{source} activity data feeds into the calculation of a quality or safety metric",
    "CORRECTS": "T&M labor, material, or equipment work performed specifically to resolve a punch item or deficiency",
    "CORRELATES WITH": "Statistical relationship between a field operations measure and a quality/safety outcome",
    "DISCOVERS": "{source} note or delivery {target} uncovers a quality defect or non-conformance in real time",
    "DISTRIBUTES": "{source} packages and sends quality/{target}s to stakeholders",
    "DOCUMENTS": "{source} formally captures the details of an {target}, incident, or deficiency",
    "EXPOSES": "{source}level reveals conditions that lead to {target}",
    "FULFILLS": "{source}assignment executes a task specified in {target} plan",
    "IDENTIFIES": "{source} narrative flags a potential {target} or coordination issue for formal follow-up",
    "INSPECTED DURING": "Scheduled work activity is the context in which a quality or {target} occurs",
    "LINKS TO": "{source} is cross-referenced to a scheduled {target} for sequencing",
    "LOGGED DURING": "{source}is captured within {target} reporting window",
    "NORMALIZES": "{source}provides the denominator for {target} or near-miss rate calculations",
    "RECEIVES": "{source}is issued {target} or formal notice",
    "RECORDS": "{source} creates the official record of an {target} visit or third-party reviewer presence",
    "REFERENCED BY": "{source}record is cited within an {target} or violation record for identification",
    "REPORTS": "{source} entry formally raises {target}, incident, or coordination issue into the QSR system",
    "REQUIRES": "{source}delivery or shipment must have an accompanying test report or {target} before acceptance",
    "RESPONDS TO": "{source} is initiated in reaction to an action plan requirement for additional resources",
    "TRACKED BY": "Waste or environmental field data is monitored through formal environmental observations",
    "TRIGGERS": "{source} event initiates a downstream quality or {target} (inspection, corrective action, test report)",
    "VERIFIED BY": "{source}is confirmed through {target} or observation"
  }
}