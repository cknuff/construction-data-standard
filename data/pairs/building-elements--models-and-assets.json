  "verbGlossary": {
    "MODELED IN": "{source} geometry and data authored inside a BIM {target}",
    "COORDINATED IN": "{source} spatially coordinated across disciplines within {target}",
    "SEQUENCED IN": "{source} linked to a construction schedule via a 4D simulation",
    "QUANTITY TAKEN OFF IN": "{source} material quantities extracted from a cost-linked {target}",
    "TESTED FOR CLASH BY": "{source} checked for spatial interference via automated {target}",
    "GENERATES": "{source} routing or placement produces {target} requiring resolution",
    "RESOLVED IN": "{source} conflict addressed during a BIM coordination meeting",
    "REPRESENTED BY": "{source} mapped to a discrete {target} element with properties",
    "DETAILED TO": "{source} {target}ed to a specific Level of Development for its project stage",
    "MEASURED BY": "{source} area, length, or volume extracted through quantity takeoff",
    "PARAMETERIZED IN": "{source} specs (capacity, load, rating) stored as {target} parameters",
    "VERIFIED AGAINST": "{source} compared to the as-built {target} for accuracy",
    "SCANNED BY": "{source} captured as point-cloud geometry via laser scanning",
    "SURVEYED BY": "{source} or site condition captured via drone aerial imagery",
    "DOCUMENTED BY": "{source} installation recorded with a construction photograph",
    "CAPTURED BY": "{source} condition recorded within a 360-degree spherical photo",
    "DRAWN FROM": "{source}generated directly from {target}",
    "MONITORED VIA": "{source} operational data streamed to a digital twin for ongoing tracking",
    "FABRICATED FROM": "{source} shop-fabricated using geometry and data exported from {target}",
    "DRIVES": "{source} design changes cause drawing revisions in {target}"
  }
