  "verbGlossary": {
    "ACTIVE DURING": "{source} is present and working on site during {target}",
    "PEAKS DURING": "{source} reaches maximum headcount or production rate during {target}",
    "BUILDS FORMWORK DURING": "{target} constructs and strips concrete forms during {source}",
    "DOES FINISH WORK IN": "{target} performs finish-phase installation (doors, trim, casework) during {source}",
    "CORRECTS DEFICIENCIES IN": "{source} returns to fix punch list items during {target}",
    "FOLLOWS STEEL ERECTION IN": "{target} applies SFRM immediately after steel erection in {source}",
    "RUNS UNDERGROUND IN": "{target} installs below-slab rough-in (piping, conduit, ductbank) during {source}",
    "TRIMS OUT IN": "{target} installs finish devices and fixtures during {source}",
    "INSPECTS WORK IN": "{target} verifies installed work against specifications during {source}",
    "PROVIDES LAYOUT FOR": "{target} establishes control points and building layout for {source}",
    "LEADS ACTIVITIES IN": "{source} leads or directs the primary activities during {target}",
    "MONITORS SAFETY IN": "{source} oversees hazard controls during {target}",
    "INSTALLS HOISTWAY IN": "{target} installs rails, guides, and hoistway equipment during {source}",
    "INSTALLS CAB IN": "{target} sets cab, doors, and interior finishes during {source}",
    "SUPPORTS STARTUP IN": "{source} participates in equipment startup and initial operations during {target}",
    "PERFORMS TESTING IN": "{target} executes functional performance testing during {source}",
    "DOES TOUCH-UP IN": "{target} performs final touch-up and repair work during {source}",
    "WITNESSES TESTING IN": "{source} observes and verifies testing during {target}",
    "RETURNS FOR": "{source} returns to site for seasonal or deferred testing in {target}",
    "MOBILIZED FOR": "{source} is brought to site and set up for use during {target}",
    "SETS EQUIPMENT IN": "{target} sets major mechanical equipment on pads or rooftops during {source}",
    "DELIVERED FOR": "{source} arrives on site for installation during {target}",
    "FABRICATED BEFORE": "{source} is fabricated off-site in advance of {target}",
    "ON LONG-LEAD PROCUREMENT BEFORE": "{source} requires early procurement due to extended fabrication lead time before {target}"
  }
}
