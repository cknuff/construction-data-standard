  "verbGlossary": {
    "OBSERVED AT": "A quality or {target} was recorded at this location",
    "INSPECTED AT": "{source}{target} was conducted at this location",
    "DEFICIENT ON": "An inspection item or notice was found deficient on a specific location element",
    "OCCURRED AT": "{target} or event took place at this location",
    "TAGGED AT": "{source}was tagged to a specific zone or space for closeout",
    "PHOTOGRAPHED AT": "{source}was photo-documented at this precise location",
    "PINNED TO": "{source} was geo-pinned or floor-plan-pinned to {target} coordinate",
    "CITED AT": "A formal {target} or citation was issued referencing this location",
    "FLAGGED AT": "{source}issue was flagged at a specific spatial location",
    "TESTED AT": "{source}performance test was conducted at this location",
    "COMMISSIONED AT": "{source}was performed at this equipment or zone",
    "SCHEDULED AT": "An inspection or walkthrough was pre-scheduled for this location",
    "DOCUMENTED AT": "{source}record or witness statement was documented referencing this location",
    "SCOPED TO": "{source}plan was scoped to address findings within this work zone",
    "ASSIGNED TO": "{source}was assigned to be resolved at this location",
    "REFERENCED AT": "{source}issue was referenced using grid-line coordinates",
    "RESOLVED AT": "{source}was completed and verified at this location",
    "MEASURED AT": "{source}was measured at the room or space level",
    "QUANTIFIED BY": "{source}-based measure is quantified by a corresponding quality/safety rate",
    "SAMPLED AT": "{source}test sample was collected at this floor or level",
    "CATEGORIZED AT": "{source}was classified by issue category at a specific room or space",
    "ISSUED AT": "{source}was formally issued referencing this location"
  }
