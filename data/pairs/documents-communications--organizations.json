  "verbGlossary": {
    "ACKNOWLEDGED BY": "{source} has formally acknowledged receipt and compliance obligations for {target}",
    "APPROVES": "{target} reviews and grants formal approval or rejection on {source}",
    "ASSIGNED TO": "{source} is the designated responsible party who must act on or resolve {target}",
    "ATTENDS": "{source} participates in the meeting as a required or invited {target}",
    "AUTHORED BY": "{source} created or produced {target} as its originator",
    "CAPTURED BY": "{source} took the photo or video as field documentation",
    "COMPILED BY": "{target} assembles {source} from contributions of multiple parties",
    "CONVENED BY": "{source} scheduled and chairs the meeting",
    "CREATED BY": "{source} established the template, form, or plan structure",
    "DISTRIBUTED BY": "{source} transmits {target} to all relevant parties on the distribution list",
    "ENFORCES": "Regulatory authority holds jurisdiction to enforce compliance with {target} requirements",
    "FILED BY": "{source} completes and submits the daily field record as the responsible site {target}",
    "FORWARDED BY": "{source} routes {target} from one party to another in the communication chain",
    "INITIATED BY": "{source} originated the request that was then formally submitted through proper channels",
    "ISSUED BY": "{source} formally releases {target} with authority to the receiving parties",
    "LOGGED BY": "{source} recorded the communication event in the project record",
    "MEASURED FOR": "{target}measure tracks performance or compliance metrics attributable to this {source}",
    "MONITORS": "{target} performs ongoing oversight or surveillance related to {source} requirements",
    "NOTIFIED BY": "{source} receives formal written notice of a condition or claim via {target}",
    "PREPARED BY": "{source} produced the technical content of {target} for submission by another party",
    "PROVIDED BY": "{source} furnishes {target} as a deliverable obligation under their contract or scope",
    "RECEIVED BY": "{source} is a designated recipient of {target} for information or action",
    "RECORDED BY": "{source} documented the proceedings and action items from the meeting",
    "REFERENCES": "{source} contains references to work performed by or conditions related to {target}",
    "REPORTED IN": "{source}'s activities or workforce are documented within the field report",
    "RESPONDED BY": "{source} provided the official response or answer to the request",
    "REVIEWED BY": "{source} examined {target} and provided comments, approval, or rejection",
    "REVIEWS": "{source} examines {target} for conformance before forwarding in the approval chain",
    "SIGNED BY": "{source} executed {target} with legal signature acknowledging its terms",
    "SUBMITTED BY": "{source} formally delivered {target} to the receiving party through project channels",
    "VERIFIED BY": "{source} confirmed the accuracy, completeness, or compliance status of {target}"
  }
}