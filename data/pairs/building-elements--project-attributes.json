  "verbGlossary": {
    "CLASSIFIED BY": "{source} type is categorized according to {target} attribute (e.g., deep vs. shallow foundation classified by foundation type)",
    "DETERMINED BY": "{source} selection or configuration is driven by {target} attribute's structural or site designation",
    "SCALED BY": "{source} scope or quantity increases proportionally with {target} (e.g., curtain wall area scales with building height)",
    "SIZED BY": "{source} capacity or count is sized based on {target} quantity (e.g., elevator count sized by number of stories)",
    "REQUIRED BY": "{source} is mandated because {target} attribute triggers a code or contractual requirement",
    "GOVERNED BY": "{source} design and installation must comply with requirements dictated by {target}, or seismic category",
    "MANDATED BY": "{source} performance threshold is required by {target} or regulatory standard",
    "SPECIFIED BY": "{source} characteristics are specified based on {target} thermal, moisture, or specialty requirements",
    "COMMISSIONED FOR": "{source} undergoes commissioning testing to satisfy the target sustainability certification's verification requirements",
    "SEGMENTED BY": "{source} installation metrics are broken down by {target} to identify type-specific patterns and benchmarks",
    "CONSTRAINED BY": "{source} scope or placement is limited by {target} site constraint attribute",
    "DRIVEN BY": "{source} inclusion or scope is primarily caused by {target} attribute's conditions",
    "INFLUENCED BY": "{source} scope is affected by {target} attribute without being solely determined by it",
    "SOURCED FROM": "{source} is prefabricated off-site as specified by {target}",
    "CREDITED TOWARD": "{source} contributes points or compliance credit toward the target sustainability certification",
    "OPTIMIZED FOR": "{source} is configured and tuned to achieve the target energy or sustainability performance goal"
  }
